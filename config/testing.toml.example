# /etc/express-blog/testing.toml
#
# Installed as a dpkg conffile -- if you've already customized this file,
# `dpkg -i`/`apt install` will not overwrite it. Used by
# express-blog@testing.service for a side-by-side instance separate from
# the release one on port 3500.

[meta]
node_env     = "testing"
site_owner   = "Jason Poage"
country      = "US"
root_dir     = "/usr/lib/expressjs-blog"
content_path = "/usr/lib/expressjs-blog/content"

[network]
schema    = "http"
domain    = "testing.jasonpoage.local"
address   = "127.0.0.1"
port      = 3501

[public]
schema  = "https"
domain  = "test.jasonpoage.com"
address = "192.168.1.200"
port    = 443

[logging]
log_dir   = "/var/log/express-blog"
log_level = "debug"

[mail]
secure          = true
host            = "smtp-relay.brevo.com"
port            = 587
domain          = "jasonpoage.com"
newsletter      = "newsletter@jasonpoage.com"
default_subject = "New Contact Form Submission"
# user = ""   # prefer MAIL_USER env var
# pass = ""   # prefer MAIL_PASS env var

[hcaptcha]
# secret = ""   # prefer HCAPTCHA_SECRET env var
# key    = ""   # prefer HCAPTCHA_KEY env var

[security]
hsts_max_age     = 63072000
healthcheck_path = "/health"
auth_domain      = "https://auth.jasonpoage.com"

[cleanup.development]
max_session_count        = 25
session_retention_hours  = 1
max_total_size_mb        = 50
max_disk_usage_percent   = 85
cleanup_interval_minutes = 15
emergency_cleanup_ratio  = 0.7
