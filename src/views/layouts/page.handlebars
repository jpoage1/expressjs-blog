<!DOCTYPE html>
<html lang="en">

<head>
  {{> site_headers }}
</head>

<body class="{{css.classes.body}}">
  {{> page_headers}}
  <div class="{{css.classes.layout}}">
    {{#if showSidebar}}
    <aside class="{{css.classes.sidebar}}">
      <nav>
        {{> postsMenu }}
      </nav>
    </aside>
    {{/if}}
    <main class="{{css.classes.container}}">
      {{{body}}}
    </main>
  </div>
  {{#if showFooter}}
  <footer>
    {{> footer}}
  </footer>
  {{/if}}
  {{{_sections.scripts}}}
</body>

</html>
